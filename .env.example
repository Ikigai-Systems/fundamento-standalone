# Fundamento Standalone Configuration
#
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# These are optional — defaults work out of the box.

# Web server port (default: 3333)
# RAILS_PORT=3333

# Public hostname used for links in emails and redirects (default: localhost:3333)
# HTTP_HOST=localhost:3333

# Log level: debug, info, warn, error, fatal (default: info)
# RAILS_LOG_LEVEL=info

# Pin a specific Fundamento version instead of :latest
# See available tags at: https://github.com/orgs/Ikigai-Systems/packages/container/package/fundamento
# FUNDAMENTO_VERSION=latest
